{
    "name": "abo-wbo/management-system",
    "description": "ABO-WBO Global Organization Management System - Comprehensive web application for managing global Oromo organizational operations",
    "type": "project",
    "keywords": ["oromo", "organization", "management", "multilingual", "php", "mysql"],
    "license": "MIT",
    "authors": [
        {
            "name": "ABO-WBO Development Team",
            "email": "dev@abo-wbo.org"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "firebase/php-jwt": "^6.8",
        "phpmailer/phpmailer": "^6.8",
        "monolog/monolog": "^2.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\": "database/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "analyse": "phpstan analyse",
        "dev": "php -S localhost:8000 -t public",
        "migrate": "php database/migrate.php",
        "seed": "php database/seed.php"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}